{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "YGT: Backend (Django)",
      "type": "shell",
      "command": "venv/Scripts/python manage.py runserver 0.0.0.0:8000",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "DJANGO_SETTINGS_MODULE": "config.settings",
          "DJANGO_DEBUG": "True"
        }
      },
      "presentation": {
        "group": "ygt",
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "YGT: Frontend (Vite)",
      "type": "shell",
      "command": "npm run dev -- --host",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "group": "ygt",
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "YGT: Run All",
      "dependsOn": ["YGT: Backend (Django)", "YGT: Frontend (Vite)"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "YGT: Kill Backend (port 8000)",
      "type": "shell",
      "command": "for /f \"tokens=5\" %a in ('netstat -aon ^| findstr :8000 ^| findstr LISTENING') do taskkill /F /PID %a",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "presentation": {
        "group": "ygt-kill",
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "YGT: Kill Frontend (port 3000)",
      "type": "shell",
      "command": "for /f \"tokens=5\" %a in ('netstat -aon ^| findstr :3000 ^| findstr LISTENING') do taskkill /F /PID %a",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "presentation": {
        "group": "ygt-kill",
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "YGT: Kill All",
      "dependsOn": ["YGT: Kill Backend (port 8000)", "YGT: Kill Frontend (port 3000)"],
      "dependsOrder": "parallel",
      "presentation": {
        "group": "ygt-kill",
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "YGT: Migrate",
      "type": "shell",
      "command": "venv/Scripts/python manage.py migrate",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "DJANGO_SETTINGS_MODULE": "config.settings"
        }
      },
      "presentation": {
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "YGT: Make Migrations",
      "type": "shell",
      "command": "venv/Scripts/python manage.py makemigrations",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "DJANGO_SETTINGS_MODULE": "config.settings"
        }
      },
      "presentation": {
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "YGT: Backend Tests",
      "type": "shell",
      "command": "venv/Scripts/python manage.py test apps.export apps.core --verbosity=2",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "DJANGO_SETTINGS_MODULE": "config.settings"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "YGT: Seed Data",
      "type": "shell",
      "command": "venv/Scripts/python manage.py seed_data",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "DJANGO_SETTINGS_MODULE": "config.settings"
        }
      },
      "presentation": {
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    }
  ]
}
