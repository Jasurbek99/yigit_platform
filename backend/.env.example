# ─────────────────────────────────────────────────────────────────
# YGT Platform — Backend environment
# Copy this file to .env and fill in real values.
# .env is gitignored. Never commit secrets.
# ─────────────────────────────────────────────────────────────────

# ── Django ──
SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── Database (production / dev MSSQL) ──
# DB_PASSWORD has no default in settings.py — startup will fail without it.
DB_NAME=YIGIT_PLATFROM_NEW
DB_USER=YigitUser
DB_PASSWORD=
DB_HOST=10.10.11.233\YIGIT
DB_PORT=

# ── Database (local test MSSQL) ──
# Used only when running `manage.py test` or pytest.
# YigitTestUser must have CREATE DATABASE rights on the local server.
TEST_DB_NAME=test_YIGIT_PLATFROM
TEST_DB_USER=YigitTestUser
TEST_DB_PASSWORD=TestPassword123!
TEST_DB_HOST=localhost
TEST_DB_PORT=

# ── CORS / CSRF ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
