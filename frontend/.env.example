# ─────────────────────────────────────────────────────────────────
# YGT Platform — Frontend environment (Vite)
# Copy this file to frontend/.env and fill in real values.
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────────

# API base URL.
# Leave empty in dev — Vite proxies /api → http://localhost:8000 (see vite.config.ts).
# In production builds, set to the absolute API origin, e.g. https://api.ygt.example.com/api/v1
VITE_API_BASE_URL=

# Use mock data instead of hitting the backend.
# 'true' → hooks return fixtures from src/mock/. Anything else → real API.
VITE_USE_MOCK=false
