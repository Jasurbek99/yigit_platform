; antd@^6 (root) conflicts with @ant-design/pro-components@2.8.10 which still
; peer-requires antd@^4 || ^5. The pro-components team has not yet shipped a
; version that supports antd@6. Until they do, we force npm to accept the
; existing lockfile resolution instead of erroring out on every install.
;
; Remove this file once @ant-design/pro-components ships a v6-compatible
; release and we bump the dep accordingly.
legacy-peer-deps=true
